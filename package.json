{
  "name": "vite-storybook-boilerplate",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "apply-versions": "yarn run-script bin/apply-versions.ts",
    "bootstrap": "yarn workspace stylelint-config turbo build --log-order=stream && yarn run-script bin/bootstrap.ts",
    "build": "yarn turbo run build",
    "dev": "yarn turbo run dev",
    "format": "yarn g:format",
    "g:dotenv": "cd $INIT_CWD && dotenvx",
    "g:dotenv-args": "echo \"--ignore=MISSING_ENV_FILE --ignore=MISSING_PRIVATE_KEY -fk $PROJECT_CWD/.env.keys -f $PROJECT_CWD/.env.defaults -f $PROJECT_CWD/.env -f $INIT_CWD/.env.defaults -f $INIT_CWD/.env.ci -f $INIT_CWD/.env --overload\"",
    "g:dotenv-get": "cd $INIT_CWD && yarn g:dotenv get $(yarn g:dotenv-args)",
    "g:dotenv-run": "cd $INIT_CWD && yarn g:dotenv run -q $(yarn g:dotenv-args)",
    "g:run-script": "cd $INIT_CWD && yarn g:dotenv-run --env=\"TS_NODE_PROJECT=$INIT_CWD/tsconfig.json\" -- node --enable-source-maps --experimental-transform-types --disable-warning=ExperimentalWarning -r $(yarn g:swc-register-path)",
    "g:swc-register-path": "yarn node -p \"require.resolve('@swc-node/register')\"",
    "postinstall": "husky",
    "lint": "yarn g:prettier --check . && yarn g:lint",
    "ls-workspaces": "yarn run-script bin/ls-workspaces.ts",
    "run-script": "yarn g:run-script"
  },
  "resolutions": {
    "@storybook/addon-vitest@npm:10.3.3": "patch:@storybook/addon-vitest@npm%3A10.3.3#~/.yarn/patches/@storybook-addon-vitest-npm-10.3.1-e0ed4c7524.patch",
    "pnp-sass-importer@npm:2.0.0": "patch:pnp-sass-importer@npm%3A2.0.0#~/.yarn/patches/pnp-sass-importer-npm-2.0.0-ab79efb9df.patch",
    "storybook-zeplin@npm:3.0.0": "patch:storybook-zeplin@npm%3A3.0.0#~/.yarn/patches/storybook-zeplin-npm-3.0.0-1df848e72d.patch",
    "typescript-plugin-css-modules@npm:5.2.0": "patch:typescript-plugin-css-modules@npm%3A5.2.0#~/.yarn/patches/typescript-plugin-css-modules-npm-5.2.0-2a105149d7.patch",
    "vite-plugin-sass-glob-import@npm:6.0.2": "patch:vite-plugin-sass-glob-import@npm%3A6.0.2#~/.yarn/patches/vite-plugin-sass-glob-import-npm-6.0.2-b079086a71.patch"
  },
  "devDependencies": {
    "@dotenvx/dotenvx": "1.61.2",
    "@swc-node/register": "1.11.1",
    "@swc/core": "1.15.30",
    "@types/glob-to-regexp": "0.4.4",
    "@types/node": "24.12.2",
    "@types/semver": "7.7.1",
    "@typescript-eslint/utils": "8.59.0",
    "@yarnpkg/core": "4.7.0",
    "@yarnpkg/fslib": "3.1.5",
    "@yarnpkg/sdks": "3.2.3",
    "arg": "5.0.2",
    "commons": "workspace:*",
    "eslint": "10.2.1",
    "glob-to-regexp": "0.4.1",
    "husky": "9.1.7",
    "playwright": "1.59.1",
    "renovate": "43.138.2",
    "semver": "7.7.4",
    "svelte-language-server": "0.17.30",
    "turbo": "2.9.6",
    "typescript": "6.0.3",
    "yaml": "2.8.3"
  },
  "packageManager": "yarn@4.14.1",
  "engines": {
    "node": ">= 22"
  }
}
