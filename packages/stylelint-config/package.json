{
  "name": "stylelint-config",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "yarn g:rimraf esm/ && yarn tsc --project tsconfig.esm.json",
    "format": "yarn g:format",
    "lint": "yarn g:prettier --check . && yarn g:lint"
  },
  "dependencies": {
    "flat": "6.0.1",
    "postcss": "8.5.13",
    "stylelint-config-hudochenkov": "13.0.2",
    "stylelint-config-prettier-scss": "1.0.0",
    "stylelint-config-standard-scss": "17.0.0",
    "stylelint-order": "8.1.1"
  },
  "devDependencies": {
    "arg": "5.0.2",
    "commons": "workspace:*",
    "eslint": "10.3.0",
    "stylelint": "17.10.0",
    "turbo": "2.9.8",
    "typescript": "6.0.3"
  },
  "peerDependencies": {
    "stylelint": "*"
  },
  "packageManager": "yarn@4.14.1"
}
