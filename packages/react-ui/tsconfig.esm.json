{
  "extends": "commons/tsconfig.esm.json",
  "compilerOptions": {
    "module": "Preserve",
    "moduleResolution": "Bundler",
    "declaration": true,
    "rewriteRelativeImportExtensions": true,
    "outDir": "esm",
    "rootDir": "."
  },
  "include": [".storybook/**/*"],
  "exclude": [".storybook/vitest.config.ts"]
}
