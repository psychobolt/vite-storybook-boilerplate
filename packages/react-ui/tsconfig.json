{
  // See issue: https://github.com/vitejs/vite/issues/21852
  // "extends": [
  //   "@tsconfig/vite-react/tsconfig.json",
  //   "commons/tsconfig.vite.json"
  // ],
  // commons/tsconfig.json
  "compilerOptions": {
    // @tsconfig/vite-react/tsconfig.json
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "jsx": "react-jsx",
    "noFallthroughCasesInSwitch": true,
    "noUncheckedSideEffectImports": true,

    // commons/tsconfig.json
    "declaration": true,
    "target": "ESNext",
    "allowSyntheticDefaultImports": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "sourceMap": true,
    "strict": true,
    "skipLibCheck": true,

    // commons/tsconfig.esm.json
    "composite": false,
    "outDir": "esm",

    // commons/tsconfig.vite.json
    "types": ["vite/client"],
    "esModuleInterop": true,
    "isolatedModules": true,
    "module": "Preserve",
    "moduleResolution": "Bundler",
    "useDefineForClassFields": true,
    "erasableSyntaxOnly": false,
    "noEmit": true,
    "allowImportingTsExtensions": true,

    "plugins": [
      {
        "name": "typescript-plugin-css-modules",
        "options": {
          "classnameTransform": "camelCase",
          "goToDefinition": true
        }
      }
    ],
    "baseUrl": "src",
    "paths": {
      ".storybook/*": ["../.storybook/*"],
      "html-ui/*": [
        "${configDir}/../html-ui/dist/*.css",
        "${configDir}/../html-ui/dist/*",
        "${configDir}/../html-ui/*"
      ],
      "react-ui": ["index.ts"],
      "react-ui/*": ["*/index.ts"]
    }
  },
  "include": [".storybook/**/*", "**/*"],
  "exclude": ["dist"],
  "references": [{ "path": "../commons/tsconfig.json" }]
}
