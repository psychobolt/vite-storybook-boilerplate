{
  "extends": [
    "@tsconfig/vite-react/tsconfig.json",
    "commons/tsconfig.vite.json"
  ],
  "compilerOptions": {
    "plugins": [
      {
        "name": "typescript-plugin-css-modules",
        "options": {
          "classnameTransform": "camelCase",
          "goToDefinition": true
        }
      }
    ],
    "outDir": "dist",
    "paths": {
      ".storybook/*": ["./.storybook/*"],
      "html-ui/*": [
        "../html-ui/src/html-ui/dist/*.css",
        "../html-ui/dist/*",
        "../html-ui/*"
      ],
      "react-ui": ["./src/index.ts"],
      "react-ui/*": ["./src/*/index.ts"],
      "*": ["./src/*"]
    }
  },
  "include": [".storybook/**/*", "**/*"],
  "exclude": ["dist"]
}
