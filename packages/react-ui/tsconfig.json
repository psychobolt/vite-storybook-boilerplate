{
  "extends": [
    "@tsconfig/vite-react/tsconfig.json",
    "commons/tsconfig.vite.json"
  ],
  "compilerOptions": {
    "plugins": [
      {
        "name": "typescript-plugin-css-modules",
        "options": {
          "classnameTransform": "camelCase",
          "goToDefinition": true,
          "rendererOptions": {
            "sass": {
              "customImporters": "commons/cjs/node-sass-importers.cjs"
            }
          }
        }
      }
    ],
    "outDir": "dist",
    "paths": {
      "@psychobolt/html-ui/*": [
        "${configDir}/../html-ui/dist/*.css",
        "${configDir}/../html-ui/dist/*",
        "${configDir}/../html-ui/*"
      ],
      "@psychobolt/react-ui": ["index.ts"],
      "@psychobolt/react-ui/*": ["*/index.ts"]
    }
  },
  "include": [".storybook/**/*", "**/*"],
  "exclude": ["dist"]
}
