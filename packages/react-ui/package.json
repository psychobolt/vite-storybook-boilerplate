{
  "name": "@psychobolt/react-ui",
  "version": "0.0.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/psychobolt/vite-storybook-boilerplate.git",
    "directory": "packages/react-ui"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./*": {
      "types": "./dist/*/index.d.ts",
      "import": "./dist/*/index.js",
      "require": "./dist/*/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "!**/*.css"
  ],
  "scripts": {
    "build": "yarn build-src && yarn build-dts",
    "build-dts": "tsc -p tsconfig.dts.json && tsc-paths -p tsconfig.dts.json",
    "build-src": "vite build",
    "build-storybook": "yarn g:storybook build --stats-json",
    "chromatic": "yarn g:chromatic",
    "coverage": "yarn test run --coverage",
    "dev": "yarn watch & yarn g:storybook dev -p $(yarn g:dotenv-get PORT)",
    "format": "yarn g:format",
    "lint": "yarn g:prettier --check . && yarn g:lint --runner stylelint --runner eslint",
    "prepack": "turbo run build",
    "start": "yarn g:dotenv-run -- http-server storybook-static",
    "test": "yarn g:vitest",
    "watch": "yarn build-src -w & yarn watch-dts",
    "watch-dts": "tsc -p tsconfig.dts.json -w & tsc-paths -p tsconfig.dts.json -w"
  },
  "dependencies": {
    "@psychobolt/html-ui": "0.0.0"
  },
  "devDependencies": {
    "@psychobolt/html-ui": "workspace:*",
    "@storybook/addon-docs": "10.2.4",
    "@storybook/addon-vitest": "10.2.4",
    "@storybook/react-vite": "10.2.4",
    "@tsconfig/vite-react": "7.0.2",
    "@types/babel__core": "7.20.5",
    "@types/prop-types": "15.7.15",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "@vitest/coverage-v8": "4.1.4",
    "babel-plugin-react-compiler": "1.0.0",
    "classnames": "2.5.1",
    "commons": "workspace:*",
    "eslint": "9.39.2",
    "glob": "13.0.0",
    "http-server": "14.1.1",
    "prop-types": "15.8.1",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "rolldown": "1.0.0-rc.15",
    "sass": "1.99.0",
    "storybook": "10.3.5",
    "stylelint": "17.6.0",
    "stylelint-config": "workspace:*",
    "turbo": "2.9.6",
    "typescript": "6.0.2",
    "typescript-plugin-css-modules": "5.2.0",
    "vite": "8.0.3",
    "vitest": "4.1.4"
  },
  "peerDependencies": {
    "prop-types": "^15.8.1",
    "react": "^18.2.0 || ^19.0.0",
    "react-dom": "^18.2.0 || ^19.0.0"
  },
  "packageManager": "yarn@4.13.0"
}
