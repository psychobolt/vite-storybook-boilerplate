{
  // See issue: https://github.com/vitejs/vite/issues/21852
  "extends": "commons/tsconfig.vite.json",
  "compilerOptions": {
    // commons/tsconfig.json
    "declaration": true,
    "target": "ESNext",
    "allowSyntheticDefaultImports": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "sourceMap": true,
    "strict": true,
    "skipLibCheck": true,

    // commons/tsconfig.esm.json
    "composite": false,

    // commons/tsconfig.vite.json
    "types": ["vite/client"],
    "esModuleInterop": true,
    "isolatedModules": true,
    "module": "Preserve",
    "moduleResolution": "Bundler",
    "useDefineForClassFields": true,
    "erasableSyntaxOnly": false,
    "noEmit": true,
    "allowImportingTsExtensions": true,

    "plugins": [
      {
        "name": "typescript-plugin-css-modules",
        "options": {
          "classnameTransform": "camelCase",
          "goToDefinition": true
        }
      }
    ],
    "baseUrl": "src",
    "outDir": "dist",
    "paths": {
      ".storybook/*": ["../.storybook/*"]
    }
  },
  "include": [".storybook/**/*", "**/*"],
  "exclude": ["dist"],
  "references": [{ "path": "../commons/tsconfig.json" }]
}
