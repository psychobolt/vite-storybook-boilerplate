{
  "name": "html-ui",
  "version": "0.0.0",
  "description": "UI Components used for the svelte-app demo",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/psychobolt/vite-storybook-boilerplate.git",
    "directory": "packages/html-ui"
  },
  "license": "MIT",
  "author": "psychobolt",
  "sideEffects": [
    "*.css"
  ],
  "type": "module",
  "exports": {
    "./*": "./dist/*",
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build",
    "build-storybook": "yarn g:storybook build --stats-json",
    "chromatic": "yarn g:chromatic",
    "coverage": "yarn g:rimraf coverage/ && yarn test --coverage",
    "dev": "yarn watch & yarn g:storybook dev -p $(yarn g:dotenv-get PORT)",
    "format": "yarn g:format",
    "lcov": "nyc report --reporter=lcov -t coverage/storybook --report-dir coverage/storybook",
    "lint": "yarn g:prettier --check . && yarn g:lint --runner stylelint --runner eslint",
    "prepack": "turbo run build",
    "start": "yarn g:dotenv-run -- http-server storybook-static",
    "test": "yarn g:test-storybook --index-json",
    "watch": "yarn build -w"
  },
  "devDependencies": {
    "@open-wc/lit-helpers": "0.7.0",
    "@storybook/addon-coverage": "3.0.1",
    "@storybook/addon-docs": "10.3.3",
    "@storybook/web-components-vite": "10.3.3",
    "@types/react-syntax-highlighter": "15.5.13",
    "classnames": "2.5.1",
    "commons": "workspace:*",
    "eslint": "10.1.0",
    "glob": "13.0.6",
    "http-server": "14.1.1",
    "lit": "3.3.2",
    "nyc": "18.0.0",
    "prettier": "3.8.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-syntax-highlighter": "16.1.1",
    "rollup-plugin-no-emit": "1.3.0",
    "sass": "1.98.0",
    "storybook": "10.3.3",
    "stylelint": "17.5.0",
    "stylelint-config": "workspace:*",
    "turbo": "2.8.20",
    "typescript": "5.9.3",
    "typescript-plugin-css-modules": "5.2.0",
    "vite": "8.0.2",
    "vite-plugin-sass-glob-import": "6.0.3"
  },
  "packageManager": "yarn@4.13.0"
}
