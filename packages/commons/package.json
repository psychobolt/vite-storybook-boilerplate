{
  "name": "commons",
  "private": true,
  "type": "module",
  "bin": {
    "lint": "esm/bin/lint.js",
    "tsc-paths": "esm/bin/tsc-paths.js"
  },
  "scripts": {
    "build": "yarn build-esm && yarn build-cjs",
    "build-cjs": "rimraf cjs/ && tsc --project tsconfig.cjs.json",
    "build-esm": "rimraf esm/ && tsc --project tsconfig.esm.json",
    "format": "yarn g:prettier --write --config esm/prettier.config.js $(echo \"${@:-.}\")",
    "g:chromatic": "cd $INIT_CWD && yarn g:dotenv-run -- chromatic",
    "g:format": "cd $INIT_CWD && yarn g:prettier --write $(echo \"${@:-.}\")",
    "g:lint": "cd $INIT_CWD && yarn tsc --noEmit && lint",
    "g:lint-staged": "cd $INIT_CWD && lint-staged",
    "g:prettier": "cd $INIT_CWD && prettier --ignore-path $PROJECT_CWD/.gitignore --ignore-path $PROJECT_CWD/packages/commons/.prettierignore --ignore-path $INIT_CWD/.gitignore --ignore-path ./.prettierignore",
    "g:rimraf": "cd $INIT_CWD && rimraf",
    "g:storybook": "cd $INIT_CWD && yarn g:run-script $(yarn g:storybook-path)",
    "g:storybook-path": "yarn bin storybook",
    "g:test-storybook": "cd $INIT_CWD && yarn g:run-script $(yarn g:test-storybook-path) --url $(yarn g:dotenv-get SB_URL)",
    "g:test-storybook-path": "yarn bin test-storybook",
    "g:vitest": "cd $INIT_CWD && yarn g:run-script $(yarn bin vitest)",
    "lint": "yarn g:prettier --check --config esm/prettier.config.js . && yarn g:lint"
  },
  "dependencies": {
    "@chromatic-com/storybook": "5.2.1",
    "@storybook/builder-vite": "10.4.1",
    "@storybook/test-runner": "0.24.4",
    "@types/eslint": "9.6.1",
    "@types/lodash": "4.17.24",
    "@types/react": "19.2.17",
    "@vitest/browser-playwright": "4.1.9",
    "arg": "5.0.2",
    "autoprefixer": "10.5.0",
    "chokidar": "5.0.0",
    "eslint-plugin-mdx": "3.8.1",
    "eslint-plugin-storybook": "10.4.1",
    "jiti": "2.7.0",
    "lint-staged": "17.0.7",
    "lodash": "4.18.1",
    "neostandard": "0.13.0",
    "pnp-sass-importer": "2.0.0",
    "postcss": "8.5.15",
    "postcss-pseudo-classes": "0.4.0",
    "postcss-scss": "4.0.9",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "storybook-multilevel-sort": "2.1.0",
    "storybook-zeplin": "4.0.1",
    "ts-enum-util": "4.1.0",
    "type-fest": "5.7.0",
    "vite-tsconfig-paths": "6.1.1"
  },
  "devDependencies": {
    "@storybook/addon-docs": "10.4.1",
    "@storybook/addon-links": "10.4.1",
    "@storybook/addon-onboarding": "10.4.1",
    "@storybook/addon-vitest": "10.4.1",
    "@storybook/global": "5.0.0",
    "@types/node": "24.13.2",
    "@typescript-eslint/utils": "8.61.1",
    "chromatic": "17.5.0",
    "eslint": "10.5.0",
    "eslint-plugin-jsonc": "3.2.0",
    "eslint-plugin-package-json": "1.3.0",
    "jest-junit": "17.0.0",
    "playwright": "1.61.0",
    "prettier": "3.8.4",
    "prettier-config-standard": "7.0.0",
    "prettier-plugin-packagejson": "3.0.2",
    "prettier-plugin-sh": "0.18.1",
    "rimraf": "6.1.3",
    "sass": "1.101.0",
    "storybook": "10.4.1",
    "stylelint": "17.13.0",
    "turbo": "2.9.18",
    "typescript": "6.0.3",
    "vite": "8.0.16",
    "vitest": "4.1.9"
  }
}
